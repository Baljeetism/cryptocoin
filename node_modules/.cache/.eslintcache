Th1.jsx",["63"],[],"import React from 'react';\r\nimport logo from './Screenshot_2022-06-22_015408-removebg-preview.png'\r\nimport { Link } from \"react-router-dom\";\r\nconst mystyle = {\r\n    width: \"150px\",\r\n    height: \"70px\"\r\n}\r\n\r\nconst Th1 = () => {\r\n\r\n    return (\r\n        <div>\r\n            <nav className=\"navbar\">\r\n\r\n                <a href=\"/\"><img src={logo} alt=\"ogm\" style={mystyle}></img></a>\r\n\r\n                <span >\r\n                    <Link style={{ textDecoration: 'none' }} to=\"/bitcoin\">Coins</Link>\r\n\r\n                </span>\r\n                <span >\r\n                    <Link style={{ textDecoration: 'none' }} to=\"/Theory\">Theory</Link>\r\n\r\n                </span>\r\n                <span >\r\n                    <Link style={{ textDecoration: 'none' }} to=\"/news\">News</Link>\r\n\r\n                </span>\r\n                <span >\r\n                    <Link style={{ textDecoration: 'none' }} to=\"/about\">About</Link>\r\n\r\n                </span>\r\n\r\n\r\n\r\n\r\n\r\n\r\n            </nav>\r\n            <h1>Bitcoin Rainbow Price Chart</h1>\r\n            <iframe src=\"https://www.blockchaincenter.net/static/rainbow-chart.html\" scrolling='no' frameBorder={0}> </iframe>\r\n            <div className=\"cpy\">\r\n                <h6>© 2022 / caesar</h6>\r\n            </div>\r\n        </div>\r\n    );\r\n}\r\n\r\nexport default Th1;\r\n","C:\\Users\\balje\\Downloads\\lol\\my-app\\src\\components\\Th2.jsx",["64"],[],"import React from 'react';\r\nimport logo from './Screenshot_2022-06-22_015408-removebg-preview.png'\r\nimport { Link, useParams } from \"react-router-dom\";\r\nimport { useEffect, useState } from 'react';\r\nimport axios from 'axios';\r\nimport DOMPurify from 'dompurify'\r\nconst mystyle = {\r\n    width: \"150px\",\r\n    height: \"70px\"\r\n}\r\n\r\nconst Th2 = (props) => {\r\n    const params = useParams()\r\n    const [Coin, setCoin] = useState({});\r\n    const url = `https://api.coingecko.com/api/v3/coins/${params.coinId}`\r\n\r\n    useEffect(() => {\r\n        axios.get(url).then((response) => {\r\n            setCoin(response.data)\r\n        }).catch((error) => {\r\n            console.log(\"error\")\r\n        })\r\n    }, [])\r\n    return (\r\n\r\n        <div>\r\n            <nav className=\"navbar\">\r\n\r\n                <a href=\"/\"><img src={logo} alt=\"ogm\" style={mystyle}></img></a>\r\n\r\n                <span >\r\n                    <Link style={{ textDecoration: 'none' }} to=\"/bitcoin\">Coins</Link>\r\n\r\n                </span>\r\n                <span >\r\n                    <Link style={{ textDecoration: 'none' }} to=\"/Theory\">Theory</Link>\r\n\r\n                </span>\r\n                <span >\r\n                    <Link style={{ textDecoration: 'none' }} to=\"/news\">News</Link>\r\n\r\n                </span>\r\n                <span >\r\n                    <Link style={{ textDecoration: 'none' }} to=\"/about\">About</Link>\r\n\r\n                </span>\r\n\r\n\r\n\r\n\r\n\r\n\r\n            </nav><br />\r\n            <br />\r\n            <div className='des'>\r\n                <div className='lamo'>\r\n                    <div>\r\n                        {/* <img src={Coin.image.small} alt=\"\" /> */}\r\n                        <h1>{Coin.id}</h1>\r\n                        <h2>${Coin.symbol}</h2>\r\n                    </div>\r\n                    <div className='renk'>\r\n                        <h1>Rank</h1>\r\n                        <h1>#{Coin.market_cap_rank}</h1>\r\n                    </div>\r\n\r\n                </div>\r\n                <div>\r\n                    <div className='pol'>\r\n                        <table>\r\n                            <thead>\r\n                                <tr>\r\n                                    <th>1h</th>\r\n                                    <th>24h</th>\r\n\r\n                                    <th>30d</th>\r\n                                    <th>1yr</th>\r\n                                </tr>\r\n                            </thead>\r\n                            <tbody>\r\n                                <tr>\r\n                                    <td>{Coin.market_data?.price_change_percentage_1h_in_currency ? <p>{Coin.market_data.price_change_percentage_1h_in_currency.usd.toFixed(1)}%</p> : null}</td>\r\n                                    <td>{Coin.market_data?.price_change_percentage_24h_in_currency ? <p>{Coin.market_data.price_change_percentage_24h_in_currency.usd.toFixed(1)}%</p> : null}</td>\r\n\r\n                                    <td>{Coin.market_data?.price_change_percentage_24h_in_currency ? <p>{Coin.market_data.price_change_percentage_30d_in_currency.usd.toFixed(1)}%</p> : null}</td>\r\n                                    <td>{Coin.market_data?.price_change_percentage_24h_in_currency ? <p>{Coin.market_data.price_change_percentage_1y_in_currency.usd.toFixed(1)}%</p> : null}</td>\r\n\r\n                                </tr>\r\n                            </tbody>\r\n                        </table>\r\n                    </div>\r\n                    <div className='content'>\r\n                        <div className='stats'>\r\n                            <div className='left'>\r\n                                <div className='row'>\r\n                                    <h4>24 Hour Low</h4>\r\n                                    {Coin.market_data?.low_24h ? <p>${Coin.market_data.low_24h.usd.toLocaleString()}</p> : null}\r\n                                </div>\r\n                                <div className='row'>\r\n                                    <h4>24 Hour High</h4>\r\n                                    {Coin.market_data?.high_24h ? <p>${Coin.market_data.high_24h.usd.toLocaleString()}</p> : null}                            </div>\r\n\r\n                            </div>\r\n                            <div className='right'>\r\n                                <div className='row'>\r\n                                    <h4>Market Cap</h4>\r\n                                    {Coin.market_data?.market_cap ? <p>${Coin.market_data.market_cap.usd.toLocaleString()}</p> : null}\r\n                                </div>\r\n                                <div className='row'>\r\n                                    <h4>Circulating Supply</h4>\r\n                                    {Coin.market_data ? <p>{Coin.market_data.circulating_supply}</p> : null}\r\n                                </div>\r\n\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n\r\n                </div>\r\n\r\n\r\n                <div className='about'>\r\n                    <h2>ABOUT COIN</h2>\r\n                    <p dangerouslySetInnerHTML={{\r\n                        __html: DOMPurify.sanitize(Coin.description ? Coin.description.en : ''),\r\n                    }}>\r\n\r\n                    </p>\r\n\r\n                </div>\r\n\r\n\r\n            </div>\r\n            <div className=\"cpy\">\r\n                <h6>© 2022 / caesar</h6>\r\n            </div>\r\n\r\n        </div>\r\n    );\r\n}\r\n\r\nexport default Th2;\r\n","C:\\Users\\balje\\Downloads\\lol\\my-app\\src\\components\\Theory.jsx",[],[],"C:\\Users\\balje\\Downloads\\lol\\my-app\\src\\components\\News.jsx",[],[],"C:\\Users\\balje\\Downloads\\lol\\my-app\\src\\components\\Newcoins.jsx",[],[],"C:\\Users\\balje\\Downloads\\lol\\my-app\\src\\components\\Corousel.jsx",["65","66","67","68"],[],"import React from \"react\";\r\nimport Slider from \"react-slick\";\r\nimport axios from \"axios\";\r\nimport { useState } from \"react\";\r\n\r\nfunction Corousel() {\r\n    // const [Name,setName]=useState([])\r\n    // const [Image,setImage]=useState([])\r\n    // const [Value,setValue]=useState([])\r\n\r\n    // const [Name1,setName1]=useState([])\r\n    // const [Image1,setImage1]=useState([])\r\n    // const [Value1,setValue1]=useState([])\